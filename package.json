{
  "name": "imagilab-monorepo",
  "private": true,
  "version": "1.1.1",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:down": "docker compose down",
    "api:types": "openapi-typescript ./docs/openapi.yaml -o ./frontend/src/generated/openapi.ts",
    "check:contract": "node scripts/check-contract-drift.mjs",
    "check:images": "node scripts/check-docker-builds.mjs",
    "check:release-smoke": "node scripts/check-release-smoke.mjs",
    "check:workflows": "node scripts/check-actionlint.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "report:licenses": "node scripts/report-licenses.mjs",
    "check": "node scripts/check.mjs",
    "e2e": "node scripts/e2e.mjs",
    "e2e:install": "npm --prefix frontend exec playwright install chromium"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}
